---
# 此文件为示例，请使用 ansible-vault create 创建加密的 secrets.yml
# 加密命令：ansible-vault create inventory/production/secrets.yml

# Let's Encrypt 证书续期通知邮箱（重要：请填写真实有效的邮箱）
certbot_email: "your-real-email@example.com"

# 数据库连接字串
db_connection_string: "Host=prod-db-host;Port=5432;Database=app;Username=prod_user;Password=production_password"

# 邮件配置
email_sender_name: "Production Site"
email_account: "admin@your-domain.com"
email_password: "production-email-password"

# S3 / DigitalOcean Spaces 配置
s3_access_key: "production-access-key"
s3_secret: "production-secret-key"
s3_url: "https://production-bucket.sgp1.digitaloceanspaces.com"
s3_cdn: "https://cdn.your-domain.com"

# Line 登录配置
line_id: "your-line-channel-id"
line_secret: "your-line-channel-secret"

# NewebPay 支付配置
newebpay_merchant_id: "your-newebpay-merchant-id"
newebpay_hash_key: "your-newebpay-hash-key"
newebpay_hash_iv: "your-newebpay-hash-iv"
