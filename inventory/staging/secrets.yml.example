---
# 此文件为示例，请使用 ansible-vault create 创建加密的 secrets.yml
# 加密命令：ansible-vault create inventory/staging/secrets.yml

# Let's Encrypt 证书续期通知邮箱（重要：请填写真实有效的邮箱）
certbot_email: "your-real-email@example.com"

# 数据库连接字串
db_connection_string: "Host=staging-db-host;Port=5432;Database=app;Username=staging_user;Password=staging_password"

# 邮件配置
email_sender_name: "Staging Site"
email_account: "staging@example.com"
email_password: "staging-email-password"

# S3 / DigitalOcean Spaces 配置
s3_access_key: "staging-access-key"
s3_secret: "staging-secret-key"
s3_url: "https://staging-bucket.sgp1.digitaloceanspaces.com"
s3_cdn: "https://staging-cdn.example.com"

# Line 登录配置
line_id: "XXX"
line_secret: "XXXXX"

# NewebPay 支付配置
newebpay_merchant_id: "MS158016826"
newebpay_hash_key: "ALjYZrXNdXzYqec0akUbQVFj0dHnWqx0"
newebpay_hash_iv: "CvEwdfCgIaxUVgmP"

# GoAccess 統計頁面認證
goaccess_admin_user: "admin"
goaccess_admin_password: "your-secure-password"
