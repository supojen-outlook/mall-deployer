# ============================================
# 环境配置文件 - 由 Ansible 自动生成
# 修改请编辑 inventory/*/secrets.yml 或 group_vars
# ============================================

# 应用版本（三个服务独立控制）
CLIENT_VERSION={{ client_version | default('v1.0.0') }}
ADMIN_VERSION={{ admin_version | default('v1.0.0') }}
API_VERSION={{ api_version | default('v1.0.0') }}

# 外部訪問端口
HOST_PORT={{ api_port }}
CLIENT_PORT={{ client_port | default(8081) }}
ADMIN_PORT={{ admin_port | default(8082) }}

# Database 連接字串
MAIN_CONNECTION_STRING={{ db_connection_string | default('') }}

# Email 設定
EMAIL_SENDER_NAME={{ email_sender_name | default('') }}
EMAIL_ACCOUNT={{ email_account | default('') }}
EMAIL_PASSWORD={{ email_password | default('') }}

# S3 / DigitalOcean Spaces 設定
S3_ACCESS_KEY={{ s3_access_key | default('') }}
S3_SECRET={{ s3_secret | default('') }}
S3_URL={{ s3_url | default('') }}
S3_CDN={{ s3_cdn | default('') }}

# Line 登录配置
LINE_ID={{ line_id | default('') }}
LINE_SECRET={{ line_secret | default('') }}

# NewebPay 支付配置
NEWEBPAY_MERCHANT_ID={{ newebpay_merchant_id | default('') }}
NEWEBPAY_HASH_KEY={{ newebpay_hash_key | default('') }}
NEWEBPAY_HASH_IV={{ newebpay_hash_iv | default('') }}
