services:
  # ĺ‰Ťç«Ż Client
  mall-client:
    image: ghcr.io/supojen-outlook/mall-client:${CLIENT_VERSION:-v1.0.0}
    container_name: mall-client
    restart: always
    ports:
      - "${CLIENT_PORT}:80"

  # ĺ‰Ťç«Ż Admin
  mall-admin:
    image: ghcr.io/supojen-outlook/mall-admin:${ADMIN_VERSION:-v1.0.0}
    container_name: mall-admin
    restart: always
    ports:
      - "${ADMIN_PORT}:80"

  # ĺľŚç«Ż API (.NET / C#)
  mall-api:
    image: ghcr.io/supojen-outlook/mall-api:${API_VERSION:-v1.0.0}
    container_name: mall-api
    restart: unless-stopped
    ports:
      - "${HOST_PORT}:7175"
    environment:
      - ASPNETCORE_ENVIRONMENT=Production
      - ASPNETCORE_URLS=http://+:7175
      - TZ=Asia/Taipei
      
      # --- .NET é…Ťç˝®ĺ°Ťć‡‰ (ä˝żç”¨é›™ĺş•ç·š) ---
      - ConnectionStrings__Main=${MAIN_CONNECTION_STRING}
      
      - EmailSettings__SenderName=${EMAIL_SENDER_NAME}
      - EmailSettings__Email=${EMAIL_ACCOUNT}
      - EmailSettings__Password=${EMAIL_PASSWORD}
      
      - S3__AccessKey=${S3_ACCESS_KEY}
      - S3__Secret=${S3_SECRET}
      - S3__Url=${S3_URL}
      - S3__CDN=${S3_CDN}
      - line__ID=${LINE_ID}
      - line__Secret=${LINE_SECRET}
      - NewebPay__MerchantID=${NEWEBPAY_MERCHANT_ID}
      - NewebPay__HashKey=${NEWEBPAY_HASH_KEY}
      - NewebPay__HashIV=${NEWEBPAY_HASH_IV}
    volumes:
      - ./keys/id_aes:/app/id_aes
      - ./keys/id_rsa.v1:/app/id_rsa.v1
      - ./keys/id_rsa.v2:/app/id_rsa.v2
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
